# ─────────────────────────────
# Discord
# ─────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USER_IDS=
# Discord Snowflake ID (숫자 18자리), 쉼표로 구분
DISCORD_ALLOWED_CHANNEL_IDS=
# 봇이 반응할 채널 ID, 쉼표로 구분 (비워두면 모든 채널 허용)
DISCORD_GUILD_ID=
# 슬래시 명령 즉시 동기화용 Guild ID(쉼표 구분, 선택)

# ─────────────────────────────
# PostgreSQL
# ─────────────────────────────
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─────────────────────────────
# n8n
# ─────────────────────────────
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=
WEBHOOK_URL=http://localhost:5678
N8N_RUNNERS_TASK_TIMEOUT=1200

# WF-09 / WF-10 채널 목록 (형식: 채널명/채널ID+채널명/채널ID+...)
TOPIC_CHANNELS=
# notebooklm-service 내부 URL
NOTEBOOKLM_SERVICE_URL=http://notebooklm-service:8090
# 채널당 최대 소스 수
NOTEBOOKLM_MAX_SOURCES=20
# WF-09 새 영상 판정 시간창(시간)
WF09_LOOKBACK_HOURS=24

# ─────────────────────────────
# Messenger Gateway
# ─────────────────────────────
GATEWAY_PORT=8080
GATEWAY_INTERNAL_SECRET=
# n8n → gateway 호출 시 인증용 시크릿

# n8n Webhook URLs
N8N_WF01_WEBHOOK_URL=http://n8n:5678/webhook/wf-01-input
N8N_WF04_WEBHOOK_URL=http://n8n:5678/webhook/wf-04-confirm-request
N8N_WF05_WEBHOOK_URL=http://n8n:5678/webhook/wf-05-confirm
N8N_WF06_WEBHOOK_URL=http://n8n:5678/webhook/wf-06-report
N8N_WF11_WEBHOOK_URL=http://n8n:5678/webhook/wf-11-tts-generate
N8N_WF12_WEBHOOK_URL=http://n8n:5678/webhook/wf-12-heygen-generate
N8N_WF08_WEBHOOK_URL=http://n8n:5678/webhook/wf-08-sns-upload

# ─────────────────────────────
# OpenAI
# ─────────────────────────────
OPENAI_API_KEY=
OPENAI_CUA_API_KEY=
# CUA 브라우저 자동화 전용 키 (권장). 비워두면 OPENAI_API_KEY 사용

# ─────────────────────────────
# NotebookLM Service
# ─────────────────────────────
NOTEBOOKLM_DEFAULT_NOTEBOOK_ID=
# 자동 로그인용 Google 계정 (2FA 비활성 계정만 사용)
GOOGLE_EMAIL=
GOOGLE_PASSWORD=

# ─────────────────────────────────────────────────────────────
# GPT-SoVITS TTS (RunPod 또는 자체 서버)
# ─────────────────────────────────────────────────────────────
TTS_API_URL=https://<runpod-id>-9880.proxy.runpod.net
# 아래 2개는 음색 클론이 필요할 때만 함께 설정 (기본은 비워두고 script_text만 사용)
TTS_REF_AUDIO_PATH=
TTS_PROMPT_TEXT=
TTS_TEXT_LANG=ko
TTS_PROMPT_LANG=ko

# ─────────────────────────────────────────────────────────────
# HeyGen
# ─────────────────────────────────────────────────────────────
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=

# ─────────────────────────────────────────────────────────────
# YouTube
# ─────────────────────────────────────────────────────────────
YOUTUBE_ACCESS_TOKEN=
YOUTUBE_CHANNEL_ID=

# ─────────────────────────────────────────────────────────────
# Instagram
# ─────────────────────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# ─────────────────────────────────────────────────────────────
# TikTok
# ─────────────────────────────────────────────────────────────
TIKTOK_ACCESS_TOKEN=

# ─────────────────────────────
# Cross-account S3 (AssumeRole)
# ─────────────────────────────
MEDIA_S3_BUCKET=
MEDIA_S3_REGION=ap-northeast-2
MEDIA_S3_ROLE_ARN=
MEDIA_S3_EXTERNAL_ID=
MEDIA_S3_ROLE_SESSION_NAME=ai-influencer-media-session
MEDIA_PRESIGN_EXPIRES_SECONDS=86400
MEDIA_MAX_DISCORD_FILE_BYTES=10485760
MEDIA_S3_PREFIX_REPORTS=reports
MEDIA_S3_PREFIX_TTS=tts
MEDIA_S3_PREFIX_VIDEOS=videos
